# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Python venv for CTI-REALM agent bridge
.venv-cti-realm/
scripts/__pycache__/

# Inspect-AI run artifacts (regenerated per run, don't commit logs)
scripts/inspect-logs/
data/inspect-logs/

# Per-run LLM swap proof artifacts (regenerate with scripts/test-llm-swap.ts)
data/llm-swap-evidence/
